# ── LLM Provider: "openai" or "gemini" ───────────────────────────────
LLM_PROVIDER=gemini

# ── OpenAI ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4
# OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# ── Google Gemini (default — matches system design) ─────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# ── LLM Runtime Stability ────────────────────────────────────────────
LLM_CONCURRENCY=10
USE_FALLBACK_FOR_RETRIES=true

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data_validation.db

# ── Redis / Distributed Controls ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS_QUEUE=false

# ── Retry settings ───────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BUDGET_PER_HOUR=1000

# ── API Security ─────────────────────────────────────────────────────
API_KEYS_STR=test-key-123
RATE_LIMIT_RPM=60

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
